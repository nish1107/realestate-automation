     * 리턴       : N/A
     * 작성일  : 2022.09.01
     * 작성자  : Inswave Systems
     */
    function checkLogger () {
         
        WebSquare.logger.mprintLog = WebSquare.logger.printLog;
        
        WebSquare.logger.printLog = function(e) {
            
            if (e.indexOf('오류') != -1) {
                
