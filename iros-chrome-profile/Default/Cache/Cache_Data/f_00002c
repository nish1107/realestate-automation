    /**
     * 함수명   : overrideGetTopWindow
     * 함수설명 : window의 Scope을 조회하는 함수 override
     *            - 서로다른 도메인이 iframe으로 구성되어 있는 경우 $p.top는 다른 도메인으로 접근할 수 있어 오류가 발생함. 
     *            - $p.top, WebSquare.util.getTopWindow 메소드를 override하여 동일 도메인의 최상위 Scope조회로 변경
     * 파라미터 : e : 이벤트 객체
     * 리턴       : N/A
     * 작성일  : 2022.09.01
     * 작성자  : Inswave Systems
     */
    function overrideGetTopWindow () {
      
        WebSquare.util.getTopWindow = function() {
            
            console.log('최상위 scope 찾기');
            
            //================================================================
            // 동일 도메인 최상위 window 찾기
            //================================================================
            var mainWin = window;
            for (var i = 0 ; i < 100 ; i ++) {
                try {
                    if (mainWin.location.href == window.parent.location.href) {
                        break;
                    } else if (mainWin.location.host == window.parent.location.host){
                        mainWin     = window.parent;
                    } else {
                        break;
                    }
                } catch(ex) {
                    break;
                }
            }
            
            //================================================================
            // 최상위 scope 조회
            //================================================================
            if (!WebSquare.strictMode) return mainWin;
            
            try {
                return mainWin.WebSquare && mainWin.WebSquare.strictModeFrame ? mainWin.WebSquare.strictModeFrame.scope : mainWin
            } catch (e) {
                return mainWin;
            }
        };
        
        WebSquare.util.getTopWindow.getAttribute       = WebSquare.session.getAttribute;
        WebSquare.util.getTopWindow.removeAttribute    = WebSquare.session.removeAttribute;
        WebSquare.util.getTopWindow.removeSession      = WebSquare.session.removeSession;
        WebSquare.util.getTopWindow.setAttribute       = WebSquare.session.setAttribute;
        
        $p.top = WebSquare.util.getTopWindow;
  }
    
    /**
